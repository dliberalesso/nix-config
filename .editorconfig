# Editor configuration, see http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
max_line_length = unset
trim_trailing_whitespace = true

# Ignore diffs/patches
[*.{diff,patch}]
end_of_line = unset
indent_size = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

[{.*,secrets}/**]
charset = unset
end_of_line = unset
indent_style = unset
indent_size = unset
insert_final_newline = unset
trim_trailing_whitespace = unset

[*.md]
indent_size = unset
